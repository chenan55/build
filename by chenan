local function move(act)
    local t = previewModel or lastSelectedModel; if not t then return end
    local cf, s = t:GetPivot(), 2.5
    if act == "F" then t:PivotTo(cf * CFrame.new(0,0,-s))
    elseif act == "B" then t:PivotTo(cf * CFrame.new(0,0,s))
    elseif act == "L" then t:PivotTo(cf * CFrame.new(-s,0,0))
    elseif act == "R" then t:PivotTo(cf * CFrame.new(s,0,0))
    elseif act == "U" then t:PivotTo(cf * CFrame.new(0,s,0))
    elseif act == "D" then t:PivotTo(cf * CFrame.new(0,-s,0))
    elseif act == "RL" then t:PivotTo(cf * CFrame.Angles(0,math.rad(15),0))
    elseif act == "RR" then t:PivotTo(cf * CFrame.Angles(0,math.rad(-15),0))
    elseif act == "TU" then t:PivotTo(cf * CFrame.Angles(math.rad(15),0,0))
    elseif act == "TD" then t:PivotTo(cf * CFrame.Angles(math.rad(-15),0,0))
    elseif act == "R_L" then t:PivotTo(cf * CFrame.Angles(0,0,math.rad(15)))
    elseif act == "R_R" then t:PivotTo(cf * CFrame.Angles(0,0,math.rad(-15))) end
end

