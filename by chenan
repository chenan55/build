local function getGroundPrecision(pos, model)
    local p = RaycastParams.new(); p.FilterDescendantsInstances = {model, player.Character}
    local ray = workspace:Raycast(pos + Vector3.new(0, 100, 0), Vector3.new(0, -300, 0), p)
    local floorY = ray and ray.Position.Y or pos.Y
    local _, size = model:GetBoundingBox()
    return Vector3.new(pos.X, floorY + (size.Y/2), pos.Z)
end

local function loadItems(category)
    for _, child in ipairs(ScrollFrame:GetChildren()) do if child:IsA("Frame") then child:Destroy() end end
    local itemCount = 0
    for _, item in ipairs(assetList) do
        if category == "Semua" or item.Category == category then
            itemCount = itemCount + 1
            local r = Instance.new("Frame")
            r.Size = UDim2.new(0.95, 0, 0, 28); r.BackgroundTransparency = 1; r.Parent = ScrollFrame
            local s = createBtn(item.Name, UDim2.new(0, 0, 0, 0), UDim2.new(0.8, -2, 1, 0), r, Color3.fromRGB(30, 30, 30))
            local d = createBtn("X", UDim2.new(0.8, 2, 0, 0), UDim2.new(0.2, -2, 1, 0), r, Color3.fromRGB(80, 30, 30))
            
            s.MouseButton1Click:Connect(function()
                if selectedButton then selectedButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30) end
                selectedButton = s; s.BackgroundColor3 = Color3.fromRGB(50, 80, 120); currentItemID = item.ID
                if previewModel then previewModel:Destroy() end
                
                resetSliderTo(1.0)
                local success, objs = pcall(function() return game:GetObjects("rbxassetid://" .. item.ID) end)
                if success and objs[1] then
                    previewModel = objs[1]; previewModel.Parent = workspace
                    for _, b in pairs(previewModel:GetDescendants()) do
                        if b:IsA("BasePart") then b.Transparency = 0.5; b.CanCollide = false; b.Anchored = true end
                    end
                    local root = player.Character.HumanoidRootPart
                    local _, bSize = previewModel:GetBoundingBox()
                    local spawnPos = root.Position + (root.CFrame.LookVector * ((bSize.Z/2) + 5))
                    previewModel:PivotTo(CFrame.new(getGroundPrecision(spawnPos, previewModel)))
                    previewModel:ScaleTo(1.0); PlaceBtn.Visible = true
                end
            end)
            d.MouseButton1Click:Connect(function()
                local list = spawnedObjects[item.ID]
                if list and #list > 0 then list[#list]:Destroy(); table.remove(list, #list); lastSelectedModel = list[#list] end
            end)
        end
    end
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, itemCount * 31)
end

