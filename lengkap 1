local function buildMenuDinamis()
    DigSpotsFolder = workspace:FindFirstChild("DigSpots")
    for _, child in pairs(DigScrollFrame:GetChildren()) do
        if not child:IsA("UIListLayout") then child:Destroy() end
    end

    if not DigSpotsFolder then return end

    for _, k in ipairs(KelangkaanData) do
        local galianDitemukan = {}
        for _, spot in pairs(DigSpotsFolder:GetChildren()) do
            if string.find(spot.Name, k.Id) then
                table.insert(galianDitemukan, spot)
            end
        end

        if #galianDitemukan > 0 then
            local CategoryGroupFrame = Instance.new("Frame", DigScrollFrame)
            CategoryGroupFrame.Size = UDim2.new(1, 0, 0, 30)
            CategoryGroupFrame.BackgroundTransparency = 1
            CategoryGroupFrame.LayoutOrder = k.Order
            
            local GroupList = Instance.new("UIListLayout", CategoryGroupFrame)
            GroupList.Padding = UDim.new(0, 3)
            GroupList.HorizontalAlignment = Enum.HorizontalAlignment.Center

            local MainCatButton = Instance.new("TextButton", CategoryGroupFrame)
            MainCatButton.Size = UDim2.new(1, -6, 0, 30)
            MainCatButton.BackgroundColor3 = WARNA_PINK_TUA 
            MainCatButton.Text = "  " .. k.Display .. " (" .. #galianDitemukan .. ")"
            MainCatButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            MainCatButton.Font = Enum.Font.Ubuntu
            MainCatButton.TextXAlignment = Enum.TextXAlignment.Left
            MainCatButton.TextSize = 13
            Instance.new("UICorner", MainCatButton).CornerRadius = UDim.new(0, 5)

            local ExpandIndicator = Instance.new("TextLabel", MainCatButton)
            ExpandIndicator.Size = UDim2.new(0, 25, 1, 0)
            ExpandIndicator.Position = UDim2.new(1, -30, 0, 0)
            ExpandIndicator.BackgroundTransparency = 1
            ExpandIndicator.Text = "[ + ]"
            ExpandIndicator.TextColor3 = Color3.fromRGB(255, 255, 255)
            ExpandIndicator.Font = Enum.Font.Ubuntu
            ExpandIndicator.TextSize = 12

            local isExpanded = false
            local SubButtonsList = {}

            for index, spotObject in ipairs(galianDitemukan) do
                local SubButton = Instance.new("TextButton", CategoryGroupFrame)
                SubButton.Size = UDim2.new(0.92, 0, 0, 28)
                SubButton.BackgroundColor3 = WARNA_UNGU 
                SubButton.Text = "📍 " .. k.Id .. " " .. index
                SubButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                SubButton.Font = Enum.Font.Ubuntu
                SubButton.TextSize = 12
                SubButton.Visible = false
                Instance.new("UICorner", SubButton).CornerRadius = UDim.new(0, 4)
                
                table.insert(SubButtonsList, SubButton)

                SubButton.MouseButton1Click:Connect(function()
                    for _, folder in pairs(DigScrollFrame:GetChildren()) do
                        if folder:IsA("Frame") then
                            for _, b in pairs(folder:GetChildren()) do
                                if b:IsA("TextButton") and b ~= MainCatButton then
                                    b.BackgroundColor3 = WARNA_UNGU 
                                end
                            end
                        end
                    end
                    SubButton.BackgroundColor3 = WARNA_BIRU 
                    TerpilihObject = spotObject
                    TerpilihName = k.Id .. " " .. index
                    StatusLabel.Text = "Target Pas: " .. TerpilihName
                    StatusLabel.TextColor3 = WARNA_BIRU 
                end)
            end

            MainCatButton.MouseButton1Click:Connect(function()
                isExpanded = not isExpanded
                if isExpanded then
                    ExpandIndicator.Text = "[ - ]"
                    CategoryGroupFrame.Size = UDim2.new(1, 0, 0, 30 + (#SubButtonsList * 31))
                    for _, subBtn in ipairs(SubButtonsList) do subBtn.Visible = true end
                else
                    ExpandIndicator.Text = "[ + ]"
                    CategoryGroupFrame.Size = UDim2.new(1, 0, 0, 30)
                    for _, subBtn in ipairs(SubButtonsList) do subBtn.Visible = false end
                end
                task.wait(0.01)
                recalculateCanvas()
            end)
        end
    end
    task.wait(0.02)
    recalculateCanvas()
end

