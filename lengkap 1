local dragging, dragInput, dragStart, startPos
local cornerArea = 40 

PlayerTeleportFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local relX = input.Position.X - PlayerTeleportFrame.AbsolutePosition.X
        local relY = input.Position.Y - PlayerTeleportFrame.AbsolutePosition.Y
        local width = PlayerTeleportFrame.AbsoluteSize.X
        local height = PlayerTeleportFrame.AbsoluteSize.Y
        
        local inTopLeft = (relX <= cornerArea and relY <= cornerArea)
        local inTopRight = (relX >= width - cornerArea and relY <= cornerArea)
        local inBottomLeft = (relX <= cornerArea and relY >= height - cornerArea)
        local inBottomRight = (relX >= width - cornerArea and relY >= height - cornerArea)

        if inTopLeft or inTopRight or inBottomLeft or inBottomRight then
            dragging = true
            dragStart = input.Position
            startPos = PlayerTeleportFrame.Position
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        if dragging then
            local delta = input.Position - dragStart
            PlayerTeleportFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
        dragging = false 
    end
end)

